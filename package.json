{
  "name": "anta",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./jsx-runtime": {
      "types": "./dist/jsx-runtime.d.ts",
      "default": "./dist/jsx-runtime.js"
    },
    "./elements": {
      "types": "./dist/elements/index.d.ts",
      "default": "./dist/elements/index.js"
    },
    "./elements/*": {
      "types": "./dist/elements/*.d.ts",
      "default": "./dist/elements/*.js"
    }
  },
  "scripts": {
    "build": "pnpm run build:js && pnpm run build:types",
    "build:js": "esbuild src/components/Progress.tsx src/index.ts src/jsx-runtime.ts src/general_types.ts src/anta_helpers.ts src/elements/index.ts src/elements/a-progress.ts --outdir=dist --outbase=src --jsx=automatic --jsx-import-source=anta --format=esm --target=ES2022 --loader:.module.css=local-css --loader:.css=global-css",
    "build:types": "tsc -p src/tsconfig.json",
    "typecheck": "tsc --noEmit -p src/tsconfig.json",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "classnames": "^2.5.0",
    "react": "^19.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  }
}
